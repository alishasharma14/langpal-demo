lePathToAssetInfo":{"123:49":{"hash":"e121956ef616581d677ae2e6a6cc278e9d9183af"},"123:47":{"hash":"b1777b8c2013b7a3ffa9f4a2f05160be41b0b336"}},"animateRootIds":[],"siteSettings":{"title":"LangPal","description":"LangPal is an AI-powered language learning platform designed to help users achieve real-world fluency through immersive, conversation-based practice. Unlike traditional language learning apps that focus on memorization, flashcards, and passive exercises, LangPal prioritizes active speaking, real-time interaction, and practical communication skills that translate directly to real-life situations.\n\nBuilt for modern learners, LangPal uses advanced artificial intelligence to simulate natural conversations across a wide range of scenarios, from everyday interactions to professional and travel-based dialogue. Users can practice speaking anytime, anywhere, gaining confidence through consistent, hands-on experience rather than rote learning. The platform provides instant, intelligent feedback on pronunciation, grammar, vocabulary usage, and overall fluency, allowing learners to improve quickly and effectively.\n\nLangPal’s adaptive learning system personalizes each user’s journey based on their skill level, goals, and progress. Whether someone is a beginner learning the basics or an advanced speaker refining their fluency, LangPal delivers tailored conversation experiences that evolve with the user. By focusing on how people actually speak in real life, LangPal bridges the gap between studying a language and truly using it.\n\nAs demand grows for faster, more effective language learning solutions, LangPal positions itself at the intersection of artificial intelligence, education technology (EdTech), and personalized learning. The platform is built to scale globally, making high-quality language education accessible, engaging, and efficient for users around the world.\n\nLangPal is redefining language learning by shifting the focus from memorization to communication, helping users speak confidently, think in their target language, and achieve fluency faster than ever before. Coming soon to iOS and Android.","scalingMode":"REFLOW","lang":"EN","googleAnalyticsID":"G-GYHK4Y0JVT","customCodeHeadStart":"<!-- Google tag (gtag.js) -->\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-GYHK4Y0JVT\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-GYHK4Y0JVT');\n</script>","faviconFilename":"b1777b8c2013b7a3ffa9f4a2f05160be41b0b336.png","socialImageFilename":"e121956ef616581d677ae2e6a6cc278e9d9183af.png","labs":{"E5FBBA911B2B7A09E649D4BE6CDF8591EAEFC881":false}},"sourceCodeHash":"04947e0c0aa02a97667495fb6aa4f713b2f518db"}